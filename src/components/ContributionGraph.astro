<section class="grid min-h-[72vh] grid-cols-1 gap-4 lg:grid-cols-[320px_1fr]">
  <aside class="rounded-2xl border border-slate-800 bg-slate-900/70 p-4 shadow-xl shadow-black/20">
    <h2 class="text-lg font-semibold text-white">Filters</h2>
    <div class="mt-4 grid gap-4">
      <label class="grid gap-2 text-sm text-slate-300">
        Days
        <input id="graph-days" class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white" type="number" min="1" max="730" value="28" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="grid gap-2 text-sm text-slate-300">
          From
          <input id="graph-from" class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white" type="date" />
        </label>
        <label class="grid gap-2 text-sm text-slate-300">
          To
          <input id="graph-to" class="rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white" type="date" />
        </label>
      </div>
      <button id="graph-apply" class="rounded-xl bg-orange-600 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-500" type="button">
        Apply range
      </button>
    </div>

    <div class="mt-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-400">Legend</h3>
      <ul id="graph-legend" class="mt-3 grid gap-2 text-sm text-slate-300"></ul>
    </div>

    <div class="mt-6 rounded-xl border border-slate-800 bg-slate-950/70 p-3 text-sm text-slate-300">
      <p id="graph-summary">Loading graph data...</p>
    </div>
  </aside>

  <div class="relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-950 shadow-2xl shadow-black/30">
    <svg id="graph-svg" class="h-[72vh] w-full" role="img" aria-label="GitHub contribution graph"></svg>
    <div id="graph-tooltip" class="pointer-events-none absolute hidden max-w-xs rounded-xl border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-100 shadow-xl"></div>
  </div>
</section>

<script>
  import * as d3 from 'd3';

  const graphUrl = '/data/graph.json';

  /** @typedef {{ id: string; label: string; type: 'root' | 'cluster' | 'repo'; owner?: string; repo?: string; radius: number; score: number; color: string; private: boolean; contributionCount: number; }} GraphNode */
  /** @typedef {{ source: string; target: string; weight: number; }} GraphLink */
  /** @typedef {{ nodes: GraphNode[]; links: GraphLink[]; generatedAt: string; defaultDays: number; events: Array<{ day: string; owner: string; repo: string; type: string; score: number; private: boolean; }>; }} GraphPayload */

  const svg = d3.select('#graph-svg');
  const tooltip = document.querySelector('#graph-tooltip');
  const summary = document.querySelector('#graph-summary');
  const legend = document.querySelector('#graph-legend');
  const daysInput = document.querySelector('#graph-days');
  const fromInput = document.querySelector('#graph-from');
  const toInput = document.querySelector('#graph-to');
  const applyButton = document.querySelector('#graph-apply');

  if (!(tooltip instanceof HTMLElement) || !(summary instanceof HTMLElement) || !(legend instanceof HTMLElement)) {
    throw new Error('Graph UI elements are missing.');
  }

  if (!(daysInput instanceof HTMLInputElement) || !(fromInput instanceof HTMLInputElement) || !(toInput instanceof HTMLInputElement) || !(applyButton instanceof HTMLButtonElement)) {
    throw new Error('Graph filter controls are missing.');
  }

  /** @type {GraphPayload | null} */
  let payload = null;

  /**
   * Formats a Date object as YYYY-MM-DD.
   * @param {Date} date Date to format.
   * @returns {string} ISO date string.
   */
  function formatDate(date) {
    return date.toISOString().slice(0, 10);
  }

  /**
   * Returns an inclusive range from the selected filter controls.
   * @returns {{ from: string; to: string }} Date range.
   */
  function getSelectedRange() {
    const today = new Date();
    const defaultDays = Number.parseInt(daysInput.value, 10) || 28;
    const to = toInput.value || formatDate(today);
    const fromDate = new Date(`${to}T00:00:00Z`);
    fromDate.setUTCDate(fromDate.getUTCDate() - Math.max(defaultDays - 1, 0));
    const from = fromInput.value || formatDate(fromDate);
    return { from, to };
  }

  /**
   * Rebuilds graph nodes and links from raw events for the selected range.
   * @param {GraphPayload} source Payload generated by the build script.
   * @param {{ from: string; to: string }} range Date range.
   * @returns {{ nodes: GraphNode[]; links: GraphLink[] }} Filtered graph.
   */
  function filterGraph(source, range) {
    const root = source.nodes.find((node) => node.type === 'root');
    if (!root) {
      throw new Error('Graph payload does not contain a root node.');
    }

    const nodeById = new Map();
    nodeById.set(root.id, { ...root });
    const clusterByOwner = new Map(source.nodes.filter((node) => node.type === 'cluster').map((node) => [node.id, node]));
    const repoTemplateById = new Map(source.nodes.filter((node) => node.type === 'repo').map((node) => [node.id, node]));
    const repoScores = new Map();
    const repoCounts = new Map();

    for (const event of source.events) {
      if (event.day < range.from || event.day > range.to) {
        continue;
      }
      const clusterId = `cluster:${event.owner}`;
      const repoId = `repo:${event.owner}/${event.repo}`;
      const cluster = clusterByOwner.get(clusterId);
      const repo = repoTemplateById.get(repoId);
      if (cluster) {
        nodeById.set(clusterId, { ...cluster });
      }
      if (repo) {
        nodeById.set(repoId, { ...repo });
        repoScores.set(repoId, (repoScores.get(repoId) ?? 0) + event.score);
        repoCounts.set(repoId, (repoCounts.get(repoId) ?? 0) + 1);
      }
    }

    for (const [id, score] of repoScores.entries()) {
      const node = nodeById.get(id);
      if (!node) {
        continue;
      }
      node.score = score;
      node.contributionCount = repoCounts.get(id) ?? 0;
      node.radius = Math.max(8, Math.min(42, 8 + Math.sqrt(score) * 4));
    }

    const nodes = Array.from(nodeById.values());
    const nodeIds = new Set(nodes.map((node) => node.id));
    const links = source.links.filter((link) => nodeIds.has(String(link.source)) && nodeIds.has(String(link.target)));
    return { nodes, links };
  }

  /**
   * Renders legend entries.
   * @param {GraphNode[]} nodes Current graph nodes.
   * @returns {void}
   */
  function renderLegend(nodes) {
    const clusters = nodes.filter((node) => node.type === 'cluster');
    legend.innerHTML = '';
    for (const cluster of clusters) {
      const item = document.createElement('li');
      item.className = 'flex items-center gap-2';
      item.innerHTML = `<span class="h-3 w-3 rounded-full" style="background:${cluster.color}"></span><span>${cluster.label}</span>`;
      legend.append(item);
    }
  }

  /**
   * Renders the force-directed graph.
   * @param {{ nodes: GraphNode[]; links: GraphLink[] }} graph Graph data.
   * @param {{ from: string; to: string }} range Date range.
   * @returns {void}
   */
  function renderGraph(graph, range) {
    svg.selectAll('*').remove();
    const element = svg.node();
    if (!(element instanceof SVGSVGElement)) {
      throw new Error('Graph SVG element is missing.');
    }

    const width = element.clientWidth || 960;
    const height = element.clientHeight || 640;
    svg.attr('viewBox', `0 0 ${width} ${height}`);

    const links = graph.links.map((link) => ({ ...link }));
    const nodes = graph.nodes.map((node) => ({ ...node }));

    const link = svg.append('g')
      .attr('stroke', '#334155')
      .attr('stroke-opacity', 0.7)
      .selectAll('line')
      .data(links)
      .join('line')
      .attr('stroke-width', (item) => Math.max(1, Math.sqrt(item.weight)));

    const node = svg.append('g')
      .selectAll('circle')
      .data(nodes)
      .join('circle')
      .attr('r', (item) => item.radius)
      .attr('fill', (item) => item.color)
      .attr('stroke', (item) => item.type === 'root' ? '#ffffff' : '#0f172a')
      .attr('stroke-width', 2)
      .call(d3.drag()
        .on('start', (event, item) => {
          if (!event.active) simulation.alphaTarget(0.3).restart();
          item.fx = item.x;
          item.fy = item.y;
        })
        .on('drag', (event, item) => {
          item.fx = event.x;
          item.fy = event.y;
        })
        .on('end', (event, item) => {
          if (!event.active) simulation.alphaTarget(0);
          item.fx = null;
          item.fy = null;
        }));

    const label = svg.append('g')
      .selectAll('text')
      .data(nodes.filter((item) => item.type !== 'repo' || item.score > 2))
      .join('text')
      .text((item) => item.label)
      .attr('font-size', (item) => item.type === 'root' ? 14 : 11)
      .attr('fill', '#e2e8f0')
      .attr('text-anchor', 'middle')
      .attr('pointer-events', 'none');

    node.on('mouseenter', (event, item) => {
      tooltip.classList.remove('hidden');
      tooltip.innerHTML = `<strong>${item.label}</strong><br>Score: ${item.score}<br>Contributions: ${item.contributionCount}`;
    }).on('mousemove', (event) => {
      tooltip.style.left = `${event.offsetX + 16}px`;
      tooltip.style.top = `${event.offsetY + 16}px`;
    }).on('mouseleave', () => {
      tooltip.classList.add('hidden');
    });

    const simulation = d3.forceSimulation(nodes)
      .force('link', d3.forceLink(links).id((item) => item.id).distance((item) => item.weight > 3 ? 110 : 80).strength(0.55))
      .force('charge', d3.forceManyBody().strength(-260))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collide', d3.forceCollide().radius((item) => item.radius + 8).iterations(2))
      .force('x', d3.forceX(width / 2).strength((item) => item.type === 'root' ? 0.25 : 0.04))
      .force('y', d3.forceY(height / 2).strength((item) => item.type === 'root' ? 0.25 : 0.04));

    simulation.on('tick', () => {
      link
        .attr('x1', (item) => item.source.x)
        .attr('y1', (item) => item.source.y)
        .attr('x2', (item) => item.target.x)
        .attr('y2', (item) => item.target.y);
      node
        .attr('cx', (item) => item.x)
        .attr('cy', (item) => item.y);
      label
        .attr('x', (item) => item.x)
        .attr('y', (item) => item.y + item.radius + 14);
    });

    const score = nodes.reduce((total, item) => total + (item.type === 'repo' ? item.score : 0), 0);
    summary.textContent = `${nodes.length} nodes, ${links.length} links, score ${score}, ${range.from} to ${range.to}.`;
    renderLegend(nodes);
  }

  /**
   * Applies filters and redraws the graph.
   * @returns {void}
   */
  function redraw() {
    if (!payload) {
      return;
    }
    const range = getSelectedRange();
    const graph = filterGraph(payload, range);
    renderGraph(graph, range);
  }

  fetch(graphUrl)
    .then((response) => {
      if (!response.ok) {
        throw new Error(`Could not load graph payload: ${response.status} ${response.statusText}`);
      }
      return response.json();
    })
    .then((data) => {
      payload = data;
      daysInput.value = String(payload.defaultDays || 28);
      redraw();
    })
    .catch((error) => {
      const message = error instanceof Error ? error.message : 'Unknown graph loading error.';
      summary.textContent = message;
      console.error(error);
    });

  applyButton.addEventListener('click', redraw);
  window.addEventListener('resize', redraw);
</script>
