---
import ContributionGraph from '../components/ContributionGraph.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="GitHub contribution graph for davidsneighbour." />
    <title>GitHub contribution graph</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
      <header class="flex flex-col gap-3 rounded-2xl border border-slate-800 bg-slate-900/70 p-5 shadow-2xl shadow-black/20 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.25em] text-orange-400">GitHub activity</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white">Contribution graph</h1>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-300">
            Repository clusters are grouped by owner and linked back to the central davidsneighbour node.
          </p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-950/60 px-4 py-3 text-sm text-slate-300">
          Default window: <strong class="text-white">28 days</strong>
        </div>
      </header>

      <ContributionGraph />
    </main>
  </body>
</html>
